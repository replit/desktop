{
  "name": "replit",
  "private": true,
  "version": "1.0.14",
  "description": "Replit Desktop App",
  "productName": "Replit",
  "scripts": {
    "build": "rimraf dist && esbuild src/main.ts src/preload.ts --target=es2020 --platform=node --format=cjs --packages=external --minify --bundle --outdir=dist",
    "ts:check": "tsc --noEmit",
    "ts:watch": "tsc --noEmit -w",
    "lint": "eslint -c .eslintrc.js --ext .ts ./src",
    "ci": "npm-run-all --parallel build ts:check lint",
    "start": "pnpm build && electron-forge start",
    "start:local": "pnpm build && cross-env REPLIT_URL=http://localhost:3000 electron-forge start",
    "start:staging": "pnpm build && cross-env REPLIT_URL=https://staging.replit.com electron-forge start",
    "package": "pnpm build && electron-forge package",
    "publish": "pnpm build && electron-forge publish",
    "release": "./scripts/release.sh",
    "make": "pnpm build && electron-forge make"
  },
  "author": "Replit",
  "main": "./dist/main.js",
  "engines": {
    "pnpm": ">=8.5.1",
    "node": ">=20.10.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild"
    ]
  },
  "prettier": {
    "trailingComma": "all",
    "singleQuote": true
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.0",
    "@electron-forge/maker-deb": "^7.11.0",
    "@electron-forge/maker-dmg": "^7.11.0",
    "@electron-forge/maker-squirrel": "^7.11.0",
    "@electron-forge/maker-zip": "^7.11.0",
    "@electron-forge/publisher-github": "^7.11.0",
    "@types/eslint": "^8.56.10",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "cpy": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "~39.8.5",
    "electron-winstaller": "^5.4.0",
    "esbuild": "^0.25.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.5.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "@sentry/electron": "^5.0.0",
    "electron-log": "^5.4.0",
    "electron-squirrel-startup": "^1.0.0",
    "electron-store": "^8.2.0"
  }
}
